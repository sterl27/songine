# Frontend local pipeline URL
VITE_LOCAL_PIPELINE_URL=http://localhost:8000

# Next.js frontend (new full-stack starter)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_LOCAL_PIPELINE_PROXY_PATH=/api/local-pipeline
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_API_URL=http://localhost:8000

# Optional: server-side AI fallback for Next API route
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b:free
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: shared rate limiting store
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Supabase upload for backend pipeline
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_service_or_anon_key_here
SUPABASE_STORAGE_BUCKET=beats
SUPABASE_JWT_SECRET=your-jwt-secret
# Optional stricter JWT checks for protected backend routes
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Backend CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
